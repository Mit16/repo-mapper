# Get from aistudio.google.com (free)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — increases rate limit from 60/hr to 5000/hr
# github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_token_here

# Absolute path to your Obsidian vault folder
# Linux example:
OBSIDIAN_VAULT_PATH=/home/harry/Documents/Vault

# Windows example:
# OBSIDIAN_VAULT_PATH=C:\Users\harry\Documents\Vault